{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "env": {
    "VERCEL": "1"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
